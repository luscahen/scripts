#!/usr/bin/env bash
set -u

DOMAIN="${1:-}"
SERVERS_LIST="servers_list.txt"

if [[ -z "$DOMAIN" ]]; then
  echo "Usage: $0 example.com"
  exit 1
fi

if [[ ! -f "$SERVERS_LIST" ]]; then
  echo "❌ ${SERVERS_LIST} not found"
  exit 1
fi

# Colors via tput (works on macOS + Linux)
tput_sgr0="$(tput sgr0 2>/dev/null || true)"
tput_red="$(tput setaf 1 2>/dev/null || true)"
tput_green="$(tput setaf 2 2>/dev/null || true)"
tput_yellow="$(tput setaf 3 2>/dev/null || true)"
tput_cyan="$(tput setaf 6 2>/dev/null || true)"
tput_bold="$(tput bold 2>/dev/null || true)"

info()    { printf "%s%s%s\n" "${tput_cyan}${tput_bold}" "$1" "${tput_sgr0}"; }
ok()      { printf "%s✔ %s%s\n" "${tput_green}" "$1" "${tput_sgr0}"; }
warn()    { printf "%s⚠ %s%s\n" "${tput_yellow}" "$1" "${tput_sgr0}"; }
bad()     { printf "%s✖ %s%s\n" "${tput_red}" "$1" "${tput_sgr0}"; }

# Given an IP, print matching server (if any) and return 0 when found
# It prints the matching server line in green
check_ip_match_and_print() {
  local ip="$1"
  # server is first column where second column equals ip (supports spaces/tabs)
  local server
  server=$(awk -v ip="$ip" '($2==ip){print $1; exit}' "$SERVERS_LIST")
  if [[ -n "$server" ]]; then
    ok "MATCH → ${server} (${ip})"
    return 0
  fi
  return 1
}

# Extract IPv4 addresses from viewdns HTML reliably (works on macOS + Linux)
# Usage: get_history_ips domain
get_history_ips() {
  local d="$1"
  curl -s "https://viewdns.info/iphistory/?domain=${d}" \
    | sed -n 's/.*<td>\([0-9]\{1,3\}\(\.[0-9]\{1,3\}\)\{3\}\)<\/td>.*/\1/p' \
    | sort -u
}

# Get current A records using host (portable)
get_current_a() {
  local name="$1"
  host "$name" 2>/dev/null | awk '/has address/ {print $4}' | sort -u
}

# Ensure subfinder exists (we use it for subdomain enumeration)
if ! command -v subfinder >/dev/null 2>&1; then
  bad "subfinder not found in PATH — required for subdomain enumeration"
  exit 1
fi

info "🔍 Checking domain: ${DOMAIN}"
echo

#
# 1) CURRENT A RECORDS for main domain — if any matches, exit early
#
info "▶ Current A Record(s) for ${DOMAIN}:"
curr_ips=$(get_current_a "$DOMAIN")

if [[ -z "$curr_ips" ]]; then
  warn "NO A RECORD FOUND for ${DOMAIN}"
else
  while IFS= read -r ip; do
    printf "  %s\n" "$ip"
    if check_ip_match_and_print "$ip"; then
      echo
      ok "Server identified (current IP). No further checks needed."
      exit 0
    else
      bad "UNKNOWN IP: $ip"
    fi
  done <<< "$curr_ips"
fi

echo
warn "No match found in main A record — continuing deeper checks…"
echo

#
# 2) HISTORICAL A RECORDS for main domain
#    If any historical IP matches, print HISTORICAL MATCH and exit
#
info "▶ Historical A Records (ViewDNS) for ${DOMAIN}:"
history_ips=$(get_history_ips "$DOMAIN")

if [[ -z "$history_ips" ]]; then
  warn "No history found or rate limited by viewdns"
else
  # We'll only print matches (compact) and also show a brief count
  history_count=$(printf "%s\n" "$history_ips" | wc -l | tr -d ' ')
  printf "  %s records found in history\n" "$history_count"
  while IFS= read -r hip; do
    if [[ -z "$hip" ]]; then continue; fi
    if check_ip_match_and_print "$hip"; then
      # Historical match found — print compact HISTORICAL MATCH in yellow and exit
      printf "\n%sHISTORICAL MATCH → %s (%s)%s\n\n" "${tput_yellow}" "$(awk -v ip="$hip" '($2==ip){print $1; exit}' "$SERVERS_LIST")" "$hip" "${tput_sgr0}"
      exit 0
    fi
  done <<< "$history_ips"
fi

echo
info "▶ Subdomain enumeration (current + historical checks):"
echo

# 3) Subdomains: enumerate with subfinder, for each:
#    - check current A records
#    - check historical A records (ViewDNS for subdomain)
# If any match found (current or historical) we print it and exit (you can change behavior)
subfinder -silent -d "$DOMAIN" | while IFS= read -r sub; do
  # skip empty lines
  [[ -z "$sub" ]] && continue

  printf "%s\n" "— ${sub}"

  # current
  sub_curr=$(get_current_a "$sub")
  if [[ -n "$sub_curr" ]]; then
    # print in-line
    printf "  current: %s\n" "$(echo "$sub_curr" | tr '\n' ' ' )"
    while IFS= read -r sip; do
      if [[ -z "$sip" ]]; then continue; fi
      if check_ip_match_and_print "$sip"; then
        ok "MATCH (subdomain current) → ${sip}"
        exit 0
      else
        bad "UNKNOWN IP (sub current): ${sip}"
      fi
    done <<< "$sub_curr"
  else
    printf "  current: (no A record)\n"
  fi

  # historical for subdomain
  sub_hist=$(get_history_ips "$sub")
  if [[ -n "$sub_hist" ]]; then
    sub_hist_count=$(printf "%s\n" "$sub_hist" | wc -l | tr -d ' ')
    printf "  history: %s records\n" "$sub_hist_count"
    while IFS= read -r ship; do
      if [[ -z "$ship" ]]; then continue; fi
      if check_ip_match_and_print "$ship"; then
        printf "\n%sHISTORICAL MATCH → %s (%s)%s\n\n" "${tput_yellow}" "$(awk -v ip="$ship" '($2==ip){print $1; exit}' "$SERVERS_LIST")" "$ship" "${tput_sgr0}"
        exit 0
      else
        bad "UNKNOWN IP (sub history): ${ship}"
      fi
    done <<< "$sub_hist"
  else
    printf "  history: (none / rate limited)\n"
  fi

  echo
done

# If we reach here, no matches found anywhere
bad "No matches found (current or historical) for domain and enumerated subdomains."
exit 2
